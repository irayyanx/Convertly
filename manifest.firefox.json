{
  "manifest_version": 3,
  "name": "Convertly - Smart Currency Converter",
  "version": "0.0.0",
  "description": "Professional currency converter. Arabic support, Math solver, and Smart UI.",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://query1.finance.yahoo.com/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "convertly-addon@alrayyan.com"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Q", "mac": "Alt+Q" },
      "description": "Open Convertly"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
